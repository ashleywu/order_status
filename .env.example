# Copy to `.env.local` (never commit .env.local).
# Generate SESSION_SECRET:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

SESSION_SECRET=PASTE_A_RANDOM_STRING_AT_LEAST_32_CHARS_LONG

# Production: bcrypt hash only. Example generator (after npm install):
#   node -e "const b=require('bcryptjs'); console.log(b.hashSync('YOUR_PLAIN_PASSCODE',12))"
APP_PASSCODE_HASH=

# LOCAL ONLY — never deploy with this. Use when NODE_ENV is not production
# if APP_PASSCODE_HASH is omitted (see lib/env.ts).
# APP_PASSCODE=dev-plaintext

# ── M3+ Airtable（Materials，`GET /api/materials`，仅服务端）
# AIRTABLE_PAT=pat...
# AIRTABLE_BASE_ID=app...
# AIRTABLE_MATERIALS_TABLE=Materials
# 或直接填表 ID，例如 tblXXXXXXXX

# ── M5+ Consumption_logs（`POST /api/consumption`，仅服务端）
# AIRTABLE_CONSUMPTION_TABLE=Consumption_logs
# Idempotency lookup window (days). Default 30 if unset.
# IDEMPOTENCY_LOOKUP_DAYS=30
