{
  "$comment": "M1 Base：与 M1.md、plan-airtable.md §2 对齐；供人工建表或后续自动化对照。",
  "version": 4,
  "tables": [
    {
      "name": "Suppliers",
      "primary_field": "name",
      "fields": [
        { "api_name": "name", "type": "singleLineText" },
        { "api_name": "notes", "type": "multilineText", "optional": true }
      ]
    },
    {
      "name": "Materials",
      "primary_field": "name",
      "fields": [
        { "api_name": "name", "type": "singleLineText" },
        { "api_name": "button_label", "type": "singleLineText", "optional": true },
        {
          "api_name": "category",
          "type": "singleSelect",
          "options": ["ingredient", "bottle", "label", "ribbon", "packaging"]
        },
        {
          "api_name": "material_group",
          "type": "singleSelect",
          "options": [
            "精油",
            "植物油",
            "纯露",
            "皂基",
            "植物蜡",
            "去离子水",
            "植物调香酒精",
            "瓶子",
            "标签",
            "产品纸盒包装",
            "产品纸盒标签",
            "订单纸盒包装",
            "订单手提袋",
            "礼盒",
            "快递纸盒",
            "打包胶带",
            "打包用的蜂窝纸",
            "牛皮泡沫纸",
            "产品卡",
            "雪梨纸",
            "填充拉菲纸",
            "面油",
            "眼油",
            "身体按摩油",
            "情绪油",
            "纯精油配方",
            "淡香水",
            "精油皂",
            "润唇膏",
            "唇油",
            "精油喷雾"
          ]
        },
        {
          "api_name": "supplier",
          "type": "multipleRecordLinks",
          "linked_table": "Suppliers"
        },
        {
          "api_name": "unit",
          "type": "singleSelect",
          "options": ["ml", "g", "drops", "piece", "sheet", "roll", "cm"]
        },
        { "api_name": "default_increment", "type": "number" },
        { "api_name": "quick_amounts", "type": "singleLineText", "optional": true },
        { "api_name": "favorite", "type": "checkbox" },
        { "api_name": "sort_order", "type": "number" },
        { "api_name": "active", "type": "checkbox" },
        { "api_name": "price", "type": "number", "optional": true, "note": "参考单价；App 新增物料表单可写" },
        { "api_name": "image", "type": "multipleAttachments", "optional": true },
        { "api_name": "notes", "type": "multilineText", "optional": true },
        { "api_name": "volume", "type": "number", "optional": true, "note": "后台规格" },
        { "api_name": "size", "type": "singleLineText", "optional": true },
        { "api_name": "color", "type": "singleLineText", "optional": true },
        { "api_name": "cap_type", "type": "singleSelect", "optional": true, "options_note": "如 dropper / flat 等" },
        {
          "api_name": "packaging_type",
          "type": "singleSelect",
          "optional": true,
          "options_note": "如 Product level / Order Level / Filling / Tape / Shipping Label"
        },
        {
          "api_name": "aroma_family",
          "type": "singleSelect",
          "optional": true,
          "options": [
            "balsamic, resinous",
            "Citrus & Fresh",
            "Spices",
            "Woody",
            "Floral",
            "Herbaceous & Green",
            "Amber & Gourmand (Resinous)",
            "Earthy",
            "Resin",
            "Flower",
            "中药种子"
          ],
          "note": "精油香调族；ingredient 行填写，其他 category 可空"
        },
        {
          "api_name": "fragrance_note",
          "type": "singleLineText",
          "optional": true,
          "note": "香调 note；勿与 notes（长文本备注）混淆。Excel 常见值如 top、(base, fixatives)，但不限制为枚举"
        },
        { "api_name": "inci_name", "type": "singleLineText", "optional": true },
        { "api_name": "botanical_name", "type": "singleLineText", "optional": true },
        { "api_name": "extraction_method", "type": "singleLineText", "optional": true },
        { "api_name": "plant_part", "type": "singleLineText", "optional": true },
        { "api_name": "origin", "type": "singleLineText", "optional": true },
        {
          "api_name": "cultivation",
          "type": "singleSelect",
          "optional": true,
          "options": ["Wild harvested", "Organic", "Conventional"]
        },
        { "api_name": "extraction_year", "type": "number", "optional": true },
        { "api_name": "safety_note", "type": "singleLineText", "optional": true },
        { "api_name": "bottling_date", "type": "date", "optional": true },
        { "api_name": "inventory", "type": "number", "optional": true }
      ]
    },
    {
      "name": "Material_batches",
      "primary_field": "batch_code",
      "fields": [
        { "api_name": "batch_code", "type": "singleLineText" },
        { "api_name": "material", "type": "multipleRecordLinks", "linked_table": "Materials" },
        { "api_name": "order_date", "type": "date" },
        { "api_name": "qty_ordered", "type": "number" },
        { "api_name": "price", "type": "number" },
        { "api_name": "shipment_fee", "type": "number" },
        { "api_name": "discount", "type": "number" },
        {
          "api_name": "supplier",
          "type": "multipleRecordLinks",
          "linked_table": "Suppliers"
        },
        { "api_name": "picture", "type": "multipleAttachments", "optional": true },
        { "api_name": "notes", "type": "multilineText", "optional": true }
      ]
    },
    {
      "name": "Consumption_logs",
      "primary_field": "log_id",
      "fields": [
        {
          "api_name": "log_id",
          "type": "autoNumber",
          "alternative_primary": "formula",
          "note": "Primary：Autonumber 或使用 Formula 生成可读键"
        },
        { "api_name": "material", "type": "multipleRecordLinks", "linked_table": "Materials" },
        {
          "api_name": "usage_type",
          "type": "singleSelect",
          "options": [
            "custom",
            "finished_product",
            "corporate_client",
            "brand_sponsorship",
            "rd_lab",
            "workshop",
            "raw_repack",
            "product_sample"
          ]
        },
        { "api_name": "quantity", "type": "number", "note": "正数" },
        {
          "api_name": "occurred_at",
          "type": "dateTime",
          "note": "业务发生时间（含时分）；不可用 Created time 替代"
        },
        { "api_name": "operator", "type": "singleLineText", "optional": true },
        { "api_name": "device_id", "type": "singleLineText", "optional": true },
        { "api_name": "client_request_id", "type": "singleLineText", "optional": true },
        { "api_name": "voided", "type": "checkbox" },
        { "api_name": "void_reason", "type": "multilineText", "optional": true },
        { "api_name": "note", "type": "multilineText", "optional": true },
        {
          "api_name": "created_at",
          "type": "createdTime",
          "optional": true,
          "note": "审计；不可替代 occurred_at"
        }
      ]
    }
  ]
}
